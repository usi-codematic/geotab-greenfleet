# Geotab Demo Database Credentials
# Register at: https://my.geotab.com/registration.html (select "Create a Demo Database")
GEOTAB_DATABASE=your_database_name
GEOTAB_USERNAME=your_email@example.com
GEOTAB_PASSWORD=your_password
GEOTAB_SERVER=my.geotab.com

# Claude API (for backend AI features)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Slack Webhook (for n8n notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
